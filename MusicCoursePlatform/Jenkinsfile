pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK21'
    }

    environment {
        // Add Anaconda MySQL to PATH (important for your setup)
        PATH = "/opt/anaconda3/bin:/usr/local/bin:${env.PATH}"

        DOCKER_IMAGE = 'music-course-platform'
        DOCKER_TAG = 'latest'
        DB_NAME = 'music_lesson_db'
    }

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                checkout scm
            }
        }

        stage('Setup Database') {
            steps {
                echo 'Creating database schema...'
                dir('MusicCoursePlatform') {
                    withCredentials([string(credentialsId: 'DB_PASSWORD', variable: 'DB_PASSWORD')]) {
                        sh '''
                            /opt/anaconda3/bin/mysql -u root -p$DB_PASSWORD < database/schema.sql
                        '''
                    }
                }
            }
        }

        stage('Build') {
            steps {
                echo 'Building project...'
                dir('MusicCoursePlatform') {
                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                echo 'Running unit tests...'
                dir('MusicCoursePlatform') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit 'MusicCoursePlatform/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Code Coverage Report') {
            steps {
                echo 'Generating JaCoCo report...'
                dir('MusicCoursePlatform') {
                    sh 'mvn jacoco:report'
                }
            }
            post {
                always {
                    jacoco(
                            execPattern: 'MusicCoursePlatform/target/jacoco.exec',
                            classPattern: 'MusicCoursePlatform/target/classes',
                            sourcePattern: 'MusicCoursePlatform/src/main/java'
                    )
                }
            }
        }

        stage('Package') {
            steps {
                echo 'Packaging application...'
                dir('MusicCoursePlatform') {
                    sh 'mvn package -DskipTests'
                }
            }
        }

        stage('Archive Artifact') {
            steps {
                echo 'Archiving JAR file...'
                archiveArtifacts artifacts: 'MusicCoursePlatform/target/*.jar',
                        fingerprint: true
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building Docker image...'
                dir('MusicCoursePlatform') {
                    sh "docker build --platform linux/amd64 -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }

        failure {
            echo 'Pipeline failed!'
        }
    }
}