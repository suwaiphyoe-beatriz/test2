<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="controller.BookingViewController"
            stylesheets="@../css/styles.css"
            prefHeight="700.0" prefWidth="1000.0">

    <!-- Top Navbar -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
            <Label text="MusicCoursePlatform" styleClass="navbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Course Booking" styleClass="secondary-button" onAction="#handleBackToDashboard"/>
            <ComboBox fx:id="languageCombo" promptText="EN" prefWidth="80"/>
            <Circle radius="20" style="-fx-fill: #E2E8F0;"/>
            <Button text="Logout" styleClass="secondary-button" onAction="#handleLogout"/>
        </HBox>
    </top>
    
    <!-- Main Content -->
    <center>
        <HBox style="-fx-background-color: #F5F5F5;" spacing="0">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>
            
            <!-- Main Card -->
            <VBox styleClass="card" spacing="20" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets top="30" right="30" bottom="30" left="30"/>
                </padding>
                
                <HBox spacing="30" alignment="TOP_LEFT" VBox.vgrow="ALWAYS">
                    <!-- Left Panel - User Info -->
                    <VBox spacing="16" prefWidth="200">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Circle radius="25" style="-fx-fill: #CBD5E0;"/>
                            <Label fx:id="userNameLabel" text="Name" styleClass="teacher-name"/>
                        </HBox>

                        <Button text="Course Booking"
                                styleClass="secondary-button"
                                onAction="#handleBackToDashboard"
                                prefWidth="180"/>
                    </VBox>
                    
                    <!-- Right Panel - Bookings List -->
                    <VBox spacing="20" HBox.hgrow="ALWAYS">
                        <Label text="My Bookings" styleClass="section-title"/>

                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                            <FlowPane fx:id="bookingsContainer" hgap="20" vgap="20">
                                <!-- Booking cards will be populated dynamically -->
                            </FlowPane>
                        </ScrollPane>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>
    </center>

    <!-- Bottom Navigation -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" style="-fx-background-color: #F5F5F5; -fx-padding: 20;">
            <Button text="‹" styleClass="back-button" onAction="#handlePrevPage"/>
            <Button text="›" styleClass="back-button" onAction="#handleNextPage"/>
        </HBox>
    </bottom>
</BorderPane>
