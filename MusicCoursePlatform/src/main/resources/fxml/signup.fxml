<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="controller.SignupController"
           styleClass="main-container"
           stylesheets="@../css/styles.css"
           prefHeight="550.0" prefWidth="450.0">
    
    <!-- Card Container -->
    <VBox styleClass="card" spacing="24" alignment="CENTER_LEFT" maxWidth="400" maxHeight="520">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        
        <!-- Header with Back Button -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Button text="‹" styleClass="back-button" onAction="#handleBackToLogin"/>
            <Label text="Sign up" styleClass="page-title"/>
        </HBox>
        
        <!-- Form Fields -->
        <VBox spacing="16">
            <TextField fx:id="usernameField" 
                       promptText="Username" 
                       styleClass="text-field"
                       prefHeight="56"/>
            
            <TextField fx:id="emailField" 
                       promptText="Email" 
                       styleClass="text-field"
                       prefHeight="56"/>
            
            <PasswordField fx:id="passwordField" 
                           promptText="Password" 
                           styleClass="password-field"
                           prefHeight="56"/>
        </VBox>
        
        <!-- Sign Up Buttons -->
        <HBox spacing="16" alignment="CENTER">
            <Button fx:id="studentButton" 
                    text="AS Student" 
                    styleClass="primary-button"
                    onAction="#handleStudentSignup"
                    prefHeight="56"
                    prefWidth="150"/>
            
            <Button fx:id="teacherButton" 
                    text="AS Teacher" 
                    styleClass="primary-button"
                    onAction="#handleTeacherSignup"
                    prefHeight="56"
                    prefWidth="150"/>
        </HBox>
        
        <!-- Login Link -->
        <HBox alignment="CENTER" spacing="4">
            <Label text="Already have an account?" style="-fx-text-fill: #718096; -fx-font-size: 14px;"/>
            <Hyperlink text="Log in" 
                       styleClass="link" 
                       onAction="#handleBackToLogin"/>
        </HBox>
        
        <!-- Error Message Label -->
        <Label fx:id="errorLabel" 
               styleClass="error-label" 
               visible="false" 
               managed="false"/>
    </VBox>
</StackPane>
