<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="controller.LoginController"
           styleClass="main-container"
           stylesheets="@../css/styles.css"
           prefHeight="500.0" prefWidth="450.0">
    
    <!-- Card Container -->
    <VBox styleClass="card" spacing="24" alignment="CENTER_LEFT" maxWidth="400" maxHeight="420">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        
        <!-- Header with Back Button -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Button text="‹" styleClass="back-button" onAction="#handleBack"/>
            <Label text="Log in" styleClass="page-title"/>
        </HBox>
        
        <!-- Form Fields -->
        <VBox spacing="16">
            <TextField fx:id="emailField" 
                       promptText="Email" 
                       styleClass="text-field"
                       prefHeight="56"/>
            
            <PasswordField fx:id="passwordField" 
                           promptText="Password" 
                           styleClass="password-field"
                           prefHeight="56"/>
        </VBox>
        
        <!-- Login Button -->
        <Button fx:id="loginButton" 
                text="Log in" 
                styleClass="primary-button"
                onAction="#handleLogin"
                maxWidth="Infinity"
                prefHeight="56"/>
        
        <!-- Sign Up Link -->
        <HBox alignment="CENTER" spacing="4">
            <Label text="Don't have an account?" style="-fx-text-fill: #718096; -fx-font-size: 14px;"/>
            <Hyperlink text="Create account" 
                       styleClass="link" 
                       onAction="#handleSignup"/>
        </HBox>
        
        <!-- Error Message Label -->
        <Label fx:id="errorLabel" 
               styleClass="error-label" 
               visible="false" 
               managed="false"/>
    </VBox>
</StackPane>
